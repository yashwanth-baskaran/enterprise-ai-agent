# Environment Variables — copy this file to .env and fill in your values
# NEVER commit .env to version control

# Your business system connection
BUSINESS_SYSTEM_URL=https://your-instance.example.com
BUSINESS_SYSTEM_DB=your_database_name
BUSINESS_SYSTEM_USER=your@email.com
BUSINESS_SYSTEM_API_KEY=your_api_key_here

# Google OAuth (if using Google Sheets / Slides output)
# credentials.json and token.json are gitignored — keep them local only
